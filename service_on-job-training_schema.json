  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the On-the-Job Training Program program at CDPL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our On-the-Job Training (OJT) program is the most effective way to develop talent. Trainees are embedded in your actual work environment, working on real projects under the guidance of experienced mentors. This immersive approach ensures that learning happens in context, skills are immediately appli"
        }
      },
      {
        "@type": "Question",
        "name": "What are the key features of the On-the-Job Training Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Key features include: Real project experience, Dedicated mentorship, Hands-on skill development, Immediate practical application."
        }
      },
      {
        "@type": "Question",
        "name": "What will I gain from the On-the-Job Training Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You will gain: Job-ready professionals, Completed real-world projects, Industry-standard coding practices, Professional work habits."
        }
      },
      {
        "@type": "Question",
        "name": "Who should attend the On-the-Job Training Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This program is ideal for: Fresh graduates entering the workforce, Career changers transitioning to tech, Junior developers seeking growth, Interns and apprentices."
        }
      },
      {
        "@type": "Question",
        "name": "What delivery formats are available for On-the-Job Training Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "3-Month Program (12 weeks): Foundation building with project work | 6-Month Program (24 weeks): Comprehensive skill development | 1-Year Program (52 weeks): Complete professional transformation"
        }
      }
    ]
  },
