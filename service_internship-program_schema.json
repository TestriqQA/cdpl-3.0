    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Internship Program program at CDPL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our Internship Programs are designed to bridge the gap between academic learning and industry requirements. We place students in real work environments where they contribute to actual projects while receiving structured mentorship and training. Interns gain hands-on experience with industry-standard"
        }
      },
      {
        "@type": "Question",
        "name": "What are the key features of the Internship Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Key features include: Real project experience, Industry mentorship, Technical and soft skills training, Portfolio building."
        }
      },
      {
        "@type": "Question",
        "name": "What will I gain from the Internship Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You will gain: Industry work experience, Completed real projects, Professional portfolio, Internship certificate."
        }
      },
      {
        "@type": "Question",
        "name": "Who should attend the Internship Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This program is ideal for: Final year engineering students, Pre-final year students, Recent graduates, Career switchers."
        }
      },
      {
        "@type": "Question",
        "name": "What delivery formats are available for Internship Program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Summer Internship (6-8 weeks): Intensive summer program | Semester Internship (3-4 months): Part-time during semester | Full-Time Internship (6 months): Comprehensive professional experience"
        }
      }
    ]
