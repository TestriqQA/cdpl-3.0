    "mainEntity": [
      {
        "@type": "Question",
        "name": "How can I contact CDPL (Cinute Digital)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can reach CDPL by phone at +91 98208 53250, by email at info@cinutedigital.com, or by visiting our office in Mumbai. You can also fill out the inquiry form on our Contact Us page."
        }
      },
      {
        "@type": "Question",
        "name": "Where is the CDPL office located?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CDPL (Cinute Digital) is located in Mumbai, Maharashtra, India. We offer both classroom training at our Mumbai center and online/hybrid learning options."
        }
      },
      {
        "@type": "Question",
        "name": "What courses does CDPL offer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CDPL offers courses in Software Testing, Data Science, Machine Learning, AI, Business Intelligence, Digital Marketing, and more. Visit our Courses page for the full list."
        }
      },
      {
        "@type": "Question",
        "name": "Does CDPL provide 100% placement assistance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, CDPL provides 100% job placement assistance including resume building, mock interviews, LinkedIn optimization, and direct connections to hiring companies."
        }
      },
      {
        "@type": "Question",
        "name": "Can I schedule a free counseling session?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. You can book a free 1:1 career counseling session with our experts by calling us, filling the form on our Contact page, or booking a call directly."
        }
      }
