  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the duration of the course?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Machine Learning and Data Visualization using R Programming Master Program is a 20-hour intensive training."
        }
      },
      {
        "@type": "Question",
        "name": "What is the mode of learning?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We offer a Hybrid (CLASSROOM + ONLINE) training pattern. Students can attend live sessions in the classroom or online, and live recording sessions are also provided for flexibility."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need prior programming experience?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The course is ideal for learners with basic R or general programming skills. We build on these fundamentals to teach advanced ML concepts."
        }
      },
      {
        "@type": "Question",
        "name": "What certification will I receive?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You will receive an internationally recognized certificate from Cinute Digital with a unique authorization QR code for validation."
        }
      },
      {
        "@type": "Question",
        "name": "Is job placement assistance provided?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, we provide 100% Job Assistance, which includes comprehensive career support like resume building, interview preparation, and access to placement drives."
        }
      },
      {
        "@type": "Question",
        "name": "What are the key R packages covered?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The course focuses on core R, RStudio, ggplot2 for visualization, and the Caret package for machine learning, along with built-in functions like lm() and glm()."
        }
      }
    ]
