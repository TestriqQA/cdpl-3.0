  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do you provide placement assistance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Our dedicated Career Services team offers resume reviews, portfolio polishing, mock interviews, and direct referrals through hiring partners."
        }
      },
      {
        "@type": "Question",
        "name": "Are the programs beginner friendly?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Each program starts with fundamentals and hands-on guided labs. No prior coding experience is required for our beginner tracks."
        }
      },
      {
        "@type": "Question",
        "name": "Will I work on live projects?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You will build job-ready skills through live or sandbox projects mirroring real business scenarios."
        }
      },
      {
        "@type": "Question",
        "name": "What makes your curriculum industry-aligned?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our modules are co-designed with practitioners from QA, Data, and DevOps."
        }
      },
      {
        "@type": "Question",
        "name": "How are classes delivered—online or in-person?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We run live online cohorts with recordings and Q&A, plus weekend doubt-clearing sessions."
        }
      }
    ]
