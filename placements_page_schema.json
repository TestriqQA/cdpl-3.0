  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the average salary package for CDPL students?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our students typically secure packages ranging from 3.5 LPA to 12 LPA, depending on their prior experience and the specific domain (QA, Data Science, or Development)."
        }
      },
      {
        "@type": "Question",
        "name": "Which companies hire from CDPL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our alumni are placed at global tech leaders including TCS, Infosys, Wipro, Accenture, Tech Mahindra, and numerous high-growth startups."
        }
      },
      {
        "@type": "Question",
        "name": "Does CDPL provide job guarantees?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We offer 'Job-Guaranteed' training programs where we provide intensive placement support, multiple interview opportunities, and career coaching until you secure a job."
        }
      }
    ]
