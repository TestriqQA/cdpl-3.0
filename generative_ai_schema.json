  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is prior experience required?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Recommended. This is an advanced program designed for learners with prior programming and basic ML knowledge. If you’re new, we provide a short prep kit to get you comfortable with Python, NumPy and basic model concepts."
        }
      },
      {
        "@type": "Question",
        "name": "What is the duration of the program?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The program includes ~55 guided hours delivered via live sessions, hands-on labs, code reviews, and a capstone aligned to Deep Learning, NLP and Generative AI."
        }
      },
      {
        "@type": "Question",
        "name": "Will I get job assistance?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You’ll receive resume & LinkedIn optimization, portfolio review, mock interviews, and curated referrals for relevant AI/ML roles."
        }
      },
      {
        "@type": "Question",
        "name": "Which tools and frameworks are covered?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "PyTorch, Hugging Face Transformers, tokenizers, vector databases, experiment tracking basics, and lightweight MLOps for safe deployments."
        }
      },
      {
        "@type": "Question",
        "name": "Do I get a certificate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You’ll receive a QR-verified certificate from Cinute Digital Pvt. Ltd. after completing assessments and the capstone project."
        }
      }
    ]
  },
