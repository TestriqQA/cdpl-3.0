  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do I need coding experience?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No—this Java course is beginner-friendly. We start with programming fundamentals, Core Java, and hands-on exercises before moving to Spring Boot and Microservices. You’ll get guided labs and mentor feedback to accelerate learning."
        }
      },
      {
        "@type": "Question",
        "name": "Will I get placement support?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We provide 100% job assistance—resume building, mock interviews, profile optimization, and referrals where applicable. You’ll graduate with portfolio projects that showcase production-style Java, REST APIs, and Cloud."
        }
      },
      {
        "@type": "Question",
        "name": "What is the weekly time commitment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The typical plan is 6–8 hours per week (live sessions + guided self-study). Flexible tracks are available if you need a lighter or faster pace."
        }
      },
      {
        "@type": "Question",
        "name": "Do I get a certificate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. You’ll earn a shareable Certificate of Completion with verifiable details. It’s designed to help with employer screening and LinkedIn visibility."
        }
      },
      {
        "@type": "Question",
        "name": "Which tools and technologies are covered?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You’ll work with Java, IntelliJ IDEA, Spring Boot, JPA/Hibernate, Maven, Git/GitHub, Docker and AWS. We also use Postman for API testing and basic CI/CD flows."
        }
      },
      {
        "@type": "Question",
        "name": "Is the program industry-relevant and secure by design?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The curriculum emphasizes clean architecture, security best practices, environment configs, and observability so your apps are ready for real-world deployments."
        }
      }
    ]
  },
