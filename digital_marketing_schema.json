        }
      },
      {
        "@type": "Question",
        "name": "Are CDPL Digital Marketing certificates globally recognized?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, our QR-verified certificates are accepted by top global employers. We also help you build a portfolio of live projects to prove your expertise."
        }
      },
