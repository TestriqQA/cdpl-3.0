    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the Workshops program at CDPL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our workshops are intensive, hands-on learning experiences designed to build practical skills that participants can immediately apply. Unlike traditional training, our workshops emphasize learning by doing. Participants work on real projects, solve actual problems, and build tangible deliverables. W"
        }
      },
      {
        "@type": "Question",
        "name": "What are the key features of the Workshops?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Key features include: Flexible duration (half-day to multi-day), Hands-on practical exercises, Latest tools and frameworks, Take-home projects and resources."
        }
      },
      {
        "@type": "Question",
        "name": "What will I gain from the Workshops?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You will gain: Practical skills in new technologies, Completed projects and code samples, Best practices documentation, Certification of completion."
        }
      },
      {
        "@type": "Question",
        "name": "Who should attend the Workshops?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This program is ideal for: Developers and engineers, QA and testing professionals, Data scientists and analysts, DevOps and infrastructure teams."
        }
      },
      {
        "@type": "Question",
        "name": "What delivery formats are available for Workshops?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Half-Day Workshop (4 hours): Focused skill-building on specific topic | Full-Day Workshop (8 hours): Comprehensive coverage with hands-on labs | 2-Day Intensive (16 hours): Deep-dive with project completion | 5-Day Bootcamp (40 hours): Complete mastery with certification"
        }
      }
    ]
