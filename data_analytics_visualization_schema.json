  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the prerequisites for this course?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basic Excel knowledge (simple formulas, basic charts) is recommended but not mandatory. The course is designed for both beginners and those with some Excel experience."
        }
      },
      {
        "@type": "Question",
        "name": "What is the course duration?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The course is 20 hours long, combining both theoretical knowledge and practical hands-on experience."
        }
      },
      {
        "@type": "Question",
        "name": "What is the learning mode?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cinute Digital offers a hybrid (Classroom + Online) training pattern. You can attend sessions in the classroom or online, with live streaming and recorded sessions available."
        }
      },
      {
        "@type": "Question",
        "name": "Will I get a certificate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, you will receive an internationally recognized certificate from Cinute Digital with a unique QR code for validation after completing all assessments and mock interviews."
        }
      },
      {
        "@type": "Question",
        "name": "What job roles can I apply for after this course?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can apply for roles like Data Analyst, Business Intelligence Analyst, Financial Analyst, Marketing Analyst, Operations Analyst, Sales Analyst, and more."
        }
      },
      {
        "@type": "Question",
        "name": "Is job assistance provided?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Cinute Digital provides 100% job assistance including resume building, interview preparation, and placement support."
        }
      },
      {
        "@type": "Question",
        "name": "What tools will I learn?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You'll master Microsoft Excel, Power Query, Power Pivot, Pivot Tables, Excel Charts, Data Analysis ToolPak, and various visualization techniques."
        }
      },
      {
        "@type": "Question",
        "name": "Are there real-world projects?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, the course includes hands-on projects like Sales Performance Analysis, Budget Variance Analysis, and Customer Insights Dashboard."
        }
      }
    ]
  },
