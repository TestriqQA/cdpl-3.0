    "mainEntity": [
      {
        "@type": "Question",
        "name": "How can CDPL mentors help me in my career?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our mentors provide 1-on-1 guidance, resume reviews, mock interviews, and technical deep-dives into QA, Data Science, and Engineering based on their real-world experience at top firms."
        }
      },
      {
        "@type": "Question",
        "name": "Are the mentors actually from top tech companies?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, our mentors currently work at or have extensive experience with companies like Infosys, Deloitte, Oracle, KPMG, and Deutsche Bank."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a cost for mentorship at CDPL?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Mentorship is an integral part of our professional training programs. Students enrolled in our courses get unlimited access to mentor-led workshops and 1-on-1 sessions."
        }
      }
